{
  "manifest_version": 3,
  "name": "Inactivity URL Loader",
  "version": "1.0",
  "description": "Carga una URL específica después de un tiempo de inactividad en el navegador.",
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Configurar Inactivity URL Loader"
  },
  "options_page": "options.html"
}
